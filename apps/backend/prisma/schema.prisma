generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum AnalyticsEventType {
  PROFILE_VIEW
  LINK_CLICK
  SOCIAL_CLICK
  TEMPLATE_IMPORT
  FILE_VIEW
  FILE_DOWNLOAD
}

enum FileAssetKind {
  AVATAR
  BANNER
  BACKGROUND_IMAGE
  BACKGROUND_VIDEO
  AUDIO
  CURSOR
  BADGE_ICON
  TEMPLATE_PREVIEW
  CUSTOM_ICON
  METADATA_IMAGE
  MUSIC_COVER
  OTHER
}

enum ReportTargetType {
  PROFILE
  TEMPLATE
  FILE
  USER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum SupportConversationStatus {
  BOT
  WAITING_FOR_STAFF
  ACTIVE
  CLOSED
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  role         UserRole  @default(USER)
  isBanned     Boolean   @default(false)
  banReason    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile                      Profile?
  sessions                     Session[]
  files                        FileAsset[]
  ownedBadges                  Badge[]               @relation("OwnedBadges")
  assignedBadges               UserBadge[]           @relation("AssignedBadges")
  templates                    Template[]
  templateLikes                TemplateLike[]
  reports                      Report[]              @relation("ReporterReports")
  reviewedReports              Report[]              @relation("ReviewerReports")
  auditLogs                    AdminAuditLog[]       @relation("ActorAuditLogs")
  reservedUsernames            ReservedUsername[]
  announcements                Announcement[]
  blogPosts                    BlogPost[]            @relation("BlogAuthor")
  blogLikes                    BlogPostLike[]
  sentFriendships              Friendship[]          @relation("FriendshipRequester")
  receivedFriendships          Friendship[]          @relation("FriendshipAddressee")
  directConversationsA         DirectConversation[]  @relation("DirectConversationUserA")
  directConversationsB         DirectConversation[]  @relation("DirectConversationUserB")
  sentMessages                 DirectMessage[]       @relation("DirectMessageSender")
  notifications                Notification[]
  forumThreads                 ForumThread[]         @relation("ForumThreadAuthor")
  forumPosts                   ForumPost[]           @relation("ForumPostAuthor")
  supportConversations         SupportConversation[] @relation("SupportConversationRequester")
  assignedSupportConversations SupportConversation[] @relation("SupportConversationAssignee")
  supportMessages              SupportMessage[]      @relation("SupportMessageAuthor")
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  csrfToken  String
  userAgent  String?
  ipHash     String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Profile {
  id              String   @id @default(cuid())
  uid             Int      @unique @default(autoincrement())
  userId          String   @unique
  displayName     String
  bio             String   @default("")
  location        String   @default("")
  layout          String   @default("minimal-text")
  statusText      String   @default("")
  discordPresence Json     @default("{}")
  musicActivity   Json     @default("{}")
  theme           Json     @default("{}")
  effects         Json     @default("{}")
  metadata        Json     @default("{}")
  embeds          Json     @default("[]")
  customCss       String   @default("")
  sanitizedCss    String   @default("")
  clickToEnter    Boolean  @default(false)
  viewCount       Int      @default(0)
  aliasSlug       String?  @unique
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  avatarFileId     String?
  bannerFileId     String?
  backgroundFileId String?
  audioFileId      String?
  cursorFileId     String?
  metadataFileId   String?

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  links  Link[]
  badges UserBadge[]
  files  FileAsset[]
  views  ProfileView[]
  clicks LinkClick[]
  events AnalyticsEvent[]

  @@index([isPublic])
  @@index([createdAt])
}

model Link {
  id         String   @id @default(cuid())
  profileId  String
  title      String
  url        String
  kind       String   @default("website")
  order      Int      @default(0)
  isVisible  Boolean  @default(true)
  clickCount Int      @default(0)
  style      Json     @default("{}")
  iconFileId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  icon    FileAsset?  @relation("LinkIcon", fields: [iconFileId], references: [id], onDelete: SetNull)
  clicks  LinkClick[]

  @@index([profileId, order])
}

model Badge {
  id          String   @id @default(cuid())
  ownerUserId String?
  slug        String   @unique
  name        String
  description String   @default("")
  color       String   @default("#8b5cf6")
  glowColor   String   @default("#8b5cf6")
  tooltip     String   @default("")
  isGlobal    Boolean  @default(false)
  iconFileId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User?       @relation("OwnedBadges", fields: [ownerUserId], references: [id], onDelete: Cascade)
  icon       FileAsset?  @relation("BadgeIcon", fields: [iconFileId], references: [id], onDelete: SetNull)
  userBadges UserBadge[]

  @@index([isGlobal])
  @@index([ownerUserId])
}

model UserBadge {
  id           String   @id @default(cuid())
  profileId    String
  badgeId      String
  assignedById String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badge      Badge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  assignedBy User?   @relation("AssignedBadges", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([profileId, badgeId])
  @@index([profileId, order])
}

model Template {
  id            String   @id @default(cuid())
  ownerUserId   String
  name          String
  description   String   @default("")
  style         String   @default("dark")
  tags          String[] @default([])
  isPublished   Boolean  @default(false)
  snapshot      Json
  importCount   Int      @default(0)
  likeCount     Int      @default(0)
  reportCount   Int      @default(0)
  previewFileId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner       User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  previewFile FileAsset?     @relation("TemplatePreview", fields: [previewFileId], references: [id], onDelete: SetNull)
  likes       TemplateLike[]

  @@index([isPublished, style])
  @@index([ownerUserId])
}

model TemplateLike {
  id         String   @id @default(cuid())
  templateId String
  userId     String
  createdAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([templateId, userId])
  @@index([userId])
}

model FileAsset {
  id            String        @id @default(cuid())
  publicId      String        @unique @default(uuid())
  ownerUserId   String
  profileId     String?
  kind          FileAssetKind @default(OTHER)
  storageDriver String        @default("local")
  objectKey     String        @unique
  originalName  String
  safeName      String
  mimeType      String
  sizeBytes     Int
  checksum      String?
  metadata      Json          @default("{}")
  isPublic      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  owner            User       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  profile          Profile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  linkIcons        Link[]     @relation("LinkIcon")
  badgeIcons       Badge[]    @relation("BadgeIcon")
  templatePreviews Template[] @relation("TemplatePreview")
  messageAttachments DirectMessage[] @relation("DirectMessageAttachment")

  @@index([ownerUserId, kind])
  @@index([profileId])
  @@index([deletedAt])
}

model AnalyticsEvent {
  id          String             @id @default(cuid())
  profileId   String?
  userId      String?
  type        AnalyticsEventType
  path        String             @default("")
  referrer    String             @default("")
  visitorHash String             @default("")
  ipHash      String             @default("")
  country     String             @default("")
  device      String             @default("")
  browser     String             @default("")
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now())

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, type, createdAt])
  @@index([userId, createdAt])
}

model ProfileView {
  id          String   @id @default(cuid())
  profileId   String
  visitorHash String
  referrer    String   @default("")
  country     String   @default("")
  device      String   @default("")
  browser     String   @default("")
  createdAt   DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, visitorHash])
  @@index([profileId, createdAt])
  @@index([profileId, visitorHash])
}

model LinkClick {
  id          String   @id @default(cuid())
  linkId      String
  profileId   String
  visitorHash String
  referrer    String   @default("")
  country     String   @default("")
  device      String   @default("")
  browser     String   @default("")
  createdAt   DateTime @default(now())

  link    Link    @relation(fields: [linkId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([profileId, createdAt])
}

model Report {
  id             String           @id @default(cuid())
  reporterUserId String?
  targetType     ReportTargetType
  targetId       String
  reason         String
  details        String           @default("")
  status         ReportStatus     @default(OPEN)
  reviewerUserId String?
  resolution     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  reporter User? @relation("ReporterReports", fields: [reporterUserId], references: [id], onDelete: SetNull)
  reviewer User? @relation("ReviewerReports", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([status, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
}

model ReservedUsername {
  id          String   @id @default(cuid())
  name        String   @unique
  normalized  String   @unique
  reason      String   @default("reserved")
  createdById String?
  createdAt   DateTime @default(now())

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  tone        String    @default("info")
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive, startsAt, endsAt])
}

model BlogPost {
  id              String    @id @default(cuid())
  authorUserId    String
  slug            String    @unique
  title           String
  excerpt         String    @default("")
  contentMarkdown String
  isPublished     Boolean   @default(true)
  isPinned        Boolean   @default(false)
  likeCount       Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author User           @relation("BlogAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  likes  BlogPostLike[]

  @@index([isPublished, isPinned, publishedAt])
  @@index([authorUserId, createdAt])
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  pairKey     String           @unique
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@index([requesterId, status])
  @@index([addresseeId, status])
}

model DirectConversation {
  id        String   @id @default(cuid())
  pairKey   String   @unique
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages DirectMessage[]
  userA    User            @relation("DirectConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User            @relation("DirectConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@index([userAId])
  @@index([userBId])
}

model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  replyToMessageId String?
  attachmentFileId String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      DirectMessage?     @relation("DirectMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      DirectMessage[]    @relation("DirectMessageReplies")
  attachment   FileAsset?         @relation("DirectMessageAttachment", fields: [attachmentFileId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([replyToMessageId])
  @@index([attachmentFileId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String    @default("")
  url       String    @default("")
  imageUrl  String    @default("")
  readAt    DateTime?
  clearedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, clearedAt, createdAt])
}

model ForumCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads ForumThread[]

  @@index([order])
}

model ForumThread {
  id           String   @id @default(cuid())
  categoryId   String
  authorUserId String
  title        String
  slug         String   @unique
  bodyMarkdown String
  isPinned     Boolean  @default(false)
  isLocked     Boolean  @default(false)
  replyCount   Int      @default(0)
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation("ForumThreadAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  posts    ForumPost[]

  @@index([categoryId, isPinned, updatedAt])
  @@index([authorUserId, createdAt])
}

model ForumPost {
  id           String   @id @default(cuid())
  threadId     String
  authorUserId String
  bodyMarkdown String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation("ForumPostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorUserId, createdAt])
}

model SupportConversation {
  id              String                    @id @default(cuid())
  requesterUserId String
  assignedStaffId String?
  subject         String                    @default("Support request")
  status          SupportConversationStatus @default(BOT)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  closedAt        DateTime?

  requester     User             @relation("SupportConversationRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  assignedStaff User?            @relation("SupportConversationAssignee", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  @@index([requesterUserId, updatedAt])
  @@index([assignedStaffId, status])
  @@index([status, updatedAt])
}

model SupportMessage {
  id             String   @id @default(cuid())
  conversationId String
  authorUserId   String?
  authorRole     String   @default("BOT")
  body           String
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?               @relation("SupportMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}
