# Shared
NODE_ENV=production
PUBLIC_APP_NAME=Vyntra
PUBLIC_APP_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080
FRONTEND_PORT=8080
BACKEND_PORT=3000
# Leave these empty for Docker Compose. The frontend nginx container proxies
# /api, /socket.io, and /health to the backend over the internal Docker network.
VITE_API_URL=
VITE_SOCKET_URL=

# Docker Compose interpolates .env values before containers start.
# Keep production secrets env-safe: use letters, numbers, _ or -.
# Do not use $, quotes, spaces, backticks, or non-ASCII characters in unquoted values.
# Good generator: openssl rand -hex 32

# PostgreSQL service credentials used by Docker Compose
POSTGRES_DB=vyntra
POSTGRES_USER=vyntra
POSTGRES_PASSWORD=replace_with_64_hex_chars_from_openssl_rand_hex_32

# Backend
PORT=3000
# Docker Compose builds the backend container DATABASE_URL from POSTGRES_* above.
# This direct DATABASE_URL is for non-Docker local backend commands.
DATABASE_URL=postgresql://vyntra:replace_with_64_hex_chars_from_openssl_rand_hex_32@127.0.0.1:5432/vyntra?schema=public
REDIS_URL=redis://127.0.0.1:6379
COOKIE_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32
SESSION_COOKIE_NAME=vyntra_session
SESSION_TTL_DAYS=30
# Set false only when testing over plain HTTP, such as http://server-ip:8080.
# Use true, or leave unset in production, when serving through HTTPS.
SESSION_COOKIE_SECURE=
TRUST_PROXY=true

# Local upload storage. This path is mounted as a Docker volume in production.
STORAGE_DIR=/app/uploads
MAX_UPLOAD_MB=100

# Bootstrap admin account used by npm run seed
SEED_ADMIN_USERNAME=owner
SEED_ADMIN_EMAIL=owner@example.com
SEED_ADMIN_PASSWORD=replace_with_a_strong_env_safe_admin_password
