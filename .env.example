# Shared
NODE_ENV=production
PUBLIC_APP_NAME=Vyntra.bio
PUBLIC_APP_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080
API_PUBLIC_URL=http://localhost:3000

# Backend
PORT=3000
DATABASE_URL=postgresql://vyntra:vyntra_password@postgres:5432/vyntra?schema=public
REDIS_URL=redis://valkey:6379
COOKIE_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=vyntra_session
SESSION_TTL_DAYS=30
TRUST_PROXY=true

# Local upload storage. This path is mounted as a Docker volume in production.
STORAGE_DIR=/app/uploads
MAX_UPLOAD_MB=30

# Bootstrap admin account used by npm run seed
SEED_ADMIN_USERNAME=owner
SEED_ADMIN_EMAIL=owner@example.com
SEED_ADMIN_PASSWORD=ChangeMeNow123!

# Database service
POSTGRES_DB=vyntra
POSTGRES_USER=vyntra
POSTGRES_PASSWORD=vyntra_password
